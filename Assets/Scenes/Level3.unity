  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The rain has stopped.\nThe forest is quiet again.\n\nOne by one, the fireflies
    rise from your hands,\ndrifting back into the air where they belong.\n\nThey
    carried you through the darkness.\nThrough the shifting paths, the storm, the
    unknown.\n\nYou don\u2019t need their light anymore.\nDawn has found its way
    through the trees.\n\nNow it\u2019s your turn to let them go.\n\nYou saved them.\nAnd
    in a way\u2026 they saved you too.\n\nMaybe the forest will heal.\nMaybe the
    light will stay.\n\nYou can only hope."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6ab78b9fe687f4b43a9913ebe5ec73f4, type: 2}
  m_sharedMaterial: {fileID: -7669742476826065, guid: 6ab78b9fe687f4b43a9913ebe5ec73f4, type: 2}
